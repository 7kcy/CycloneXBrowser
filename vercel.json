{
  "version": 2,
  "builds": [
    { "src": "api/search.js", "use": "@vercel/node" },
    { "src": "api/proxy.js",  "use": "@vercel/node" },
    { "src": "public/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/search", "dest": "/api/search.js" },
    { "src": "/api/proxy",  "dest": "/api/proxy.js"  },
    {
      "src": "/ac/(.*)",
      "dest": "/api/proxy.js?url=https%3A%2F%2Fduckduckgo.com%2Fac%2F$1"
    },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
